#!/bin/bash

# Define the key file path
KEY_FILE="$HOME/.ssh/id_rsa"


# Check if the private key already exists
if [[ -f "$KEY_FILE" ]]; then
  echo "SSH private key already exists at $KEY_FILE. Skipping generation."
else
  # Create the .ssh directory if it doesn't exist
  mkdir -p "$HOME/.ssh"
  chmod 700 "$HOME/.ssh"

  # Generate the SSH private key with no passphrase
  ssh-keygen -t rsa -b 4096 -f "$KEY_FILE" -N ""
  
  # Set proper permissions
  chmod 600 "$KEY_FILE"
  
  echo "SSH private key generated at $KEY_FILE."
fi


# Update authorized keys from public keys in github
#!/bin/bash

# Path to authorized_keys file
AUTHORIZED_KEYS_FILE="$HOME/.ssh/authorized_keys"

# Ensure the .ssh directory exists
mkdir -p "$HOME/.ssh"
chmod 700 "$HOME/.ssh"

# Clear existing authorized_keys file
echo "# Automatically generated by chezmoi from GitHub public keys" > "$AUTHORIZED_KEYS_FILE"

# Fetch and append keys for each GitHub user
{{ range .users }}
echo "Fetching keys for GitHub user: {{ . }}"
response=$(curl -s "https://github.com/{{ . }}.keys")
if [[ -n "$response" ]]; then
  echo "# Keys from {{ . }}" >> "$AUTHORIZED_KEYS_FILE"
  echo "$response" >> "$AUTHORIZED_KEYS_FILE"
else
  echo "No keys found for GitHub user: {{ . }}"
fi
{{ end }}

# Set proper permissions
chmod 600 "$AUTHORIZED_KEYS_FILE"

echo "Authorized keys updated at $AUTHORIZED_KEYS_FILE."
